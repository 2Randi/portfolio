mport React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport { AiFillGithub, AiFillInstagram } from \"react-icons/ai\";\nimport { FaLinkedinIn, FaFacebookF, FaGoogle } from \"react-icons/fa\";\n\nfunction Footer() {\n  let date = new Date();\n  let year = date.getFullYear();\n  return (\n    <Container fluid className=\"footer\">\n      <Row>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Designed and Developed by RANDRIAMISAINA Tsiory</h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Copyright © {year} RANDRIAMISAINA Tsiory</h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-body\">\n          <ul className=\"footer-icons\">\n            <li className=\"social-icons\">\n              <a\n                href=\"https://github.com/2Randi\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <AiFillGithub />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.linkedin.com/in/t-fanomezana-r/\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <FaLinkedinIn />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.instagram.com/tsiory_randi/\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <AiFillInstagram />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"mailto:fano.randriamisaina@gmail.com/\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <FaGoogle />\n              </a>\n            </li>\n          </ul>\n        </Col>\n      </Row>\n    </Container>\n  );\n}\n\nexport default Footer;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/home_page/HomePage.js",["156"],[],"import React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport Particle from \"../../Particle\";\nimport Typing from \"./Typing\";\nimport Tilt from \"react-parallax-tilt\";\nimport AboutmeContainer from \"../../components/aboutme/aboutmeContainer\";\nimport Fade from \"react-reveal/Fade\";\nimport { AiFillGithub, AiFillInstagram } from \"react-icons/ai\";\nimport { FaLinkedinIn, FaFacebookF, FaGoogle } from \"react-icons/fa\";\nimport Certification from \"../../components/certificate/Certification\";\nimport Projects from \"../../components/projects/Projects\";\nimport Contactus from \"../../components/contactus/Contactus\";\n\nexport default function Home() {\n  return (\n    <section className=\"home-section\">\n      <Container fluid id=\"home\">\n        <Particle />\n        <Container className=\"home-content\">\n          <Row>\n            <Col md={8} className=\"home-header\">\n              <h1\n                style={{ paddingBottom: 15, fontSize: \"175px\" }}\n                className=\"heading\"\n              >\n                Hi There!{\" \"}\n                <span className=\"wave\" role=\"img\" aria-labelledby=\"wave\">\n                  👋🏻\n                </span>\n              </h1>\n\n              <h1 className=\"heading-name\">\n                I'M\n                <strong className=\"main-name\"> RANDRIAMISAINA Tsiory</strong>\n              </h1>\n\n              <div className=\"typing-homeclass\">\n                <Typing />\n              </div>\n              <div className=\"sociallink-home\">\n                <ul className=\"homeaboutsociallinks\">\n                  <li className=\"socialicons\">\n                    <a\n                      href=\"https://github.com/2Randi\"\n                      target=\"_blank\"\n                      rel=\"noreferrer\"\n                      className=\"iconcolour  homesocialicons\"\n                    >\n                      <AiFillGithub />\n                    </a>\n                  </li>\n                  <li className=\"socialicons\">\n                    <a\n                      href=\"https://www.linkedin.com/in/t-fanomezana-r/\"\n                      target=\"_blank\"\n                      rel=\"noreferrer\"\n                      className=\"iconcolour  homesocialicons\"\n                    >\n                      <FaLinkedinIn />\n                    </a>\n                  </li>\n                  <li className=\"socialicons\">\n                    <a\n                      href=\"https://www.instagram.com/tsiory_randi/\"\n                      target=\"_blank\"\n                      rel=\"noreferrer\"\n                      className=\"iconcolour homesocialicons\"\n                    >\n                      <AiFillInstagram />\n                    </a>\n                  </li>\n                  \n                  <li className=\"socialicons\">\n                    <a\n                      href=\"mailto:fano.randriamisaina@gmail.com\"\n                      target=\"_blank\"\n                      rel=\"noreferrer\"\n                      className=\"iconcolour homesocialicons\"\n                    >\n                      <FaGoogle />\n                    </a>\n                  </li>\n                </ul>\n              </div>\n            </Col>\n            <Col md={4} style={{ paddingBottom: 20 }}>\n              <div className=\"img-home-main\">\n                <Tilt>\n                  <Fade cascade>\n                    <img\n                      src=\"./profile.png\"\n                      alt=\"home pic\"\n                      className=\"img-fluid\"\n                    />\n                  </Fade>\n                </Tilt>\n              </div>\n            </Col>\n          </Row>\n        </Container>\n      </Container>\n      <AboutmeContainer />\n      <Certification />\n      <Projects />\n      <Contactus />\n    </section>\n  );\n}","/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/resume_page/ResumePage.js",["157"],[],"import { Container } from \"react-bootstrap\";\nimport Button from \"react-bootstrap/Button\";\nimport { AiOutlineDownload } from \"react-icons/ai\";\nimport Particle from \"../../Particle\";\nimport pdf from \"../../assets/RANDRIAMISAINA_CV.pdf\";\nimport { Document, Page, pdfjs } from \"react-pdf\";\nimport \"react-pdf/dist/esm/Page/AnnotationLayer.css\";\nimport Zoom from \"react-reveal/Zoom\";\nimport React, { useState, useEffect } from \"react\";\npdfjs.GlobalWorkerOptions.workerSrc = `//cdnjs.cloudflare.com/ajax/libs/pdf.js/${pdfjs.version}/pdf.worker.min.js`;\n\n{/* lien du CV dans github */}\nconst resumeLink =\n  \"https://github.com/2Randi/portfolio/tree/master/src/assets/RANDRIAMISAINA_CV.pdf\";\n\nfunction Resume() {\n  const [width, setWidth] = useState(1200);\n\n  useEffect(() => {\n    setWidth(window.innerWidth);\n  }, []);\n\n  return (\n    <div>\n      <section className=\"home-section\">\n        <Container fluid id=\"home\">\n          <Particle />\n          <Container className=\"home-content\">\n            <div\n              className=\"d-flex justify-content-center\"\n              width=\"100%\"\n              style={{ backgroundColor: \"#fbd9ad\" }}\n            >\n              <Zoom left cascade>\n                <h1 style={{ color: \"rgb(134 61 176)\" }}>RESUME</h1>\n              </Zoom>\n            </div>\n            <div fluid className=\"certificate-section\" id=\"about\">\n              <div className=\"d-flex justify-content-center mt-4\">\n                <Button variant=\"primary\" href={pdf} target=\"_blank\">\n                  <AiOutlineDownload />\n                  &nbsp;Download Resume\n                </Button>\n              </div>\n              <div className=\"resume d-flex justify-content-center\">\n                <Document file={resumeLink}>\n                  <Page pageNumber={1} scale={width > 786 ? 1.6 : 0.4} />\n                </Document>\n              </div>\n              <div className=\"d-flex justify-content-center\">\n                <Button variant=\"primary\" href={pdf} target=\"_blank\">\n                  <AiOutlineDownload />\n                  &nbsp;Download Resume\n                </Button>\n              </div>\n            </div>\n          </Container>\n        </Container>\n      </section>\n    </div>\n  );\n}\n\nexport default Resume;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/project_page/ProjectPage.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/certificate_page/CertificatePage.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/comingsoon_page/comingsoon.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/blogs_page/notfound.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/about/About.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/ranking/Ranking.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/EducationJourney.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/ExperienceJourney.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/TechnicalJourney.js",["158"],[],"import React from \"react\";\nimport {\n  VerticalTimeline,\n  VerticalTimelineElement,\n} from \"react-vertical-timeline-component\";\nimport { Link } from \"react-router-dom\";\nimport StarIcon from \"@mui/icons-material/Star\";\nimport ComputerIcon from \"@mui/icons-material/Computer\";\nimport {\n  DiHtml5,\n  DiPython,\n  DiReact,\n  DiPhp,\n  DiJava,\n  DiCss3,\n  DiJavascript1,\n  DiMysql,\n  DiNodejs,\n} from \"react-icons/di\";\nimport Flip from \"react-reveal/Flip\";\n\nfunction TechnicalJourney() {\n  return (\n    <div className=\"mt-5\">\n      <div>\n        <Link className=\"btn btn-primary m-1\" to=\"/educationjourney\">\n          Educational Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/experiencejourney\">\n          Experience Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/technicaljourney\">\n          Technical Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/projectjourney\">\n          Project Journey\n        </Link>\n      </div>\n      <div className=\"mt-5\">\n        <Flip top cascade>\n          <h1>Technical Journey</h1>\n        </Flip>\n      </div>\n\n      <VerticalTimeline>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<ComputerIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            LINUX ADMINISTRATION\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<ComputerIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n             NETWORKING (TCP/IP, VLAN, ROUTING, VPN)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiJava />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            VIRTUALIZATION (PROXMOX, VMWARE)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiPython />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            SECURITY (PFSENSE, IPTABLES)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiHtml5 />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            MONITORING (ZABBIX, GRAFANA)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiCss3 />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            PYTHON\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiJavascript1 />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            JAVA\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiPhp />}\n        >\n          <h3 className=\"vertical-timeline-element-title\"> \n            ASH & POWERSHELL SCRIPTING\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiMysql />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            DATABASES (POSTGRESQL, MARIADB, SQL SERVER, MONGODB)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiNodejs />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            GIT & VERSION CONTROL\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          iconStyle={{ background: \"#fbd9ad\", color: \"rgb(78 22 112)\" }}\n          icon={<StarIcon />}\n        />\n      </VerticalTimeline>\n\n    </div>\n  );\n}\n\nexport default TechnicalJourney;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/ProjectJourney.js",["159","160","161"],[],"import React from \"react\";\nimport {\n  VerticalTimeline,\n  VerticalTimelineElement,\n} from \"react-vertical-timeline-component\";\nimport { Link } from \"react-router-dom\";\nimport StarIcon from \"@mui/icons-material/Star\";\nimport JavascriptIcon from '@mui/icons-material/Javascript';\nimport CssIcon from '@mui/icons-material/Css';\nimport HtmlIcon from '@mui/icons-material/Html';\nimport CodeIcon from '@mui/icons-material/Code';\nimport Flip from \"react-reveal/Flip\";\n\nfunction ProjectJourney() {\n  return (\n    <div className=\"mt-5\">\n      <div>\n        <Link className=\"btn btn-primary m-1\" to=\"/educationjourney\">\n          Educational Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/experiencejourney\">\n          Experience Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/technicaljourney\">\n          Technical Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/projectjourney\">\n          Project Journey\n        </Link>\n      </div>\n      <div className=\"mt-5\">\n        <Flip top cascade>\n          <h1>Project Journey</h1>\n        </Flip>\n      </div>\n\n      <VerticalTimeline>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid rgb(78 22 112)\" }}\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<CodeIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Automated Operating System Deployment with FOG Project\n          </h3>\n          <p>\n            Deployment and management of system images for automated workstation provisioning.\n          </p>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid rgb(78 22 112)\" }}\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<CodeIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Linux Infrastructure Services Deployment\n          </h3>\n          <p>\n            Installation and administration of Asterisk, OpenVPN, GLPI and Zabbix services.\n          </p>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid rgb(78 22 112)\" }}\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<CodeIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Virtual Machine Backup and Migration\n          </h3>\n          <p>\n            Backup, restoration and migration of virtual machines in a Proxmox environment.\n          </p>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid rgb(78 22 112)\" }}\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<CodeIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Retrieval-Augmented Generation (RAG) System\n          </h3>\n          <p>\n            Development of a RAG solution using Python and semantic data sources.\n          </p>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid rgb(78 22 112)\" }}\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<CodeIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Knowledge Graph Exploration and Querying\n          </h3>\n          <p>\n            RDF/SKOS graph indexing and querying with Python in a research environment.\n          </p>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          iconStyle={{ background: \"#fbd9ad\", color: \"rgb(78 22 112)\" }}\n          icon={<StarIcon />}\n        />\n      </VerticalTimeline>\n\n    </div>\n  );\n}\n\nexport default ProjectJourney;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/skills/PersonalSkill.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/skills/TechnicalSkill.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/skills/Toolkit.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/social_media/SocialMedia.js",["162"],[],"import React, { useContext } from \"react\";\nimport {\n  AiOutlineInstagram,\n  AiFillFacebook,\n  AiFillGithub,\n  AiFillLinkedin,\n} from \"react-icons/ai\";\nimport { Container, Row } from \"react-bootstrap\";\nimport { Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport LanguageContext from \"../../../LanguageContext\";\n\nexport default function SocialMedia() {\n  const { t } = useContext(LanguageContext);\n  return (\n    <div className=\"mt-4\">\n      <Zoom left cascade>\n        <h1>{t.socialMedia.title}</h1>\n      </Zoom>\n      <Container className=\"mt-5\">\n        <Row className=\"g-5\">\n\n          <Col md={3}>\n            <a\n              href=\"https://www.instagram.com/tsiory_randi/\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiOutlineInstagram />\n              </Zoom>\n            </a>\n          </Col>\n\n          <Col md={3}>\n            <a\n              href=\"https://github.com/2Randi\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiFillGithub />\n              </Zoom>\n            </a>\n          </Col>\n          <Col md={3}>\n            <a\n              href=\"https://www.linkedin.com/in/t-fanomezana-r/\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiFillLinkedin />\n              </Zoom>\n            </a>\n          </Col>\n        </Row>\n      </Container>\n    </div>\n  );\n}\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/Particle.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/home_page/Typing.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/aboutmeContainer.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/certificate/Certification.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/contactus/Contactus.js",["163"],[],"import React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport { useState } from \"react\";\nimport { AiOutlineSend } from \"react-icons/ai\";\nimport { FiPhone, FiAtSign } from \"react-icons/fi\";\nimport { HiOutlineLocationMarker } from \"react-icons/hi\";\n\nexport default function Contactus() {\n  const [formData, setFormData] = useState({\n    name: \"\",\n    email: \"\",\n    message: \"\"\n  });\n\n  const handleChange = (e) => {\n    setFormData({\n      ...formData,\n      [e.target.name]: e.target.value\n    });\n  };\n\n  const handleSubmit = async (e) => {\n    e.preventDefault();\n\n    try {\n      const res = await fetch(\"https://formspree.io/f/mdadlqrg\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Accept: \"application/json\"\n        },\n        body: JSON.stringify(formData)\n      });\n\n      if (res.ok) {\n        alert(`Message envoyé, merci ${formData.name}`);\n        setFormData({ name: \"\", email: \"\", message: \"\" });\n      } else {\n        alert(\"Erreur envoi message\");\n      }\n    } catch (err) {\n      alert(\"Erreur réseau\");\n    }\n  };\n\n  return (\n    <Container fluid className=\"certificate-section\" id=\"about\">\n      <Container>\n        <Row>\n\n          {/* TITLE */}\n          <Col md={12} className=\"d-flex justify-content-start\">\n            <Zoom left cascade>\n              <h1 className=\"aboutme-heading\">Contact me</h1>\n            </Zoom>\n          </Col>\n\n          <Col md={12} className=\"mt-3\">\n            <Row>\n\n              {/* FORM */}\n              <Col md={4}>\n                <form onSubmit={handleSubmit} className=\"contacts-form\">\n\n                  <div className=\"input-container d-flex flex-column\">\n                    <label>Full Name</label>\n                    <input\n                      type=\"text\"\n                      name=\"name\"\n                      value={formData.name}\n                      onChange={handleChange}\n                      placeholder=\"Enter your name\"\n                      required\n                    />\n                  </div>\n\n                  <div className=\"input-container d-flex flex-column\">\n                    <label>Email</label>\n                    <input\n                      type=\"email\"\n                      name=\"email\"\n                      value={formData.email}\n                      onChange={handleChange}\n                      placeholder=\"Enter email\"\n                      required\n                    />\n                  </div>\n\n                  <div className=\"input-container d-flex flex-column\">\n                    <label>Message</label>\n                    <textarea\n                      name=\"message\"\n                      value={formData.message}\n                      onChange={handleChange}\n                      placeholder=\"Enter message\"\n                      rows=\"4\"\n                      required\n                    />\n                  </div>\n\n                  <button type=\"submit\" className=\"submitBtn\">\n                    Submit <AiOutlineSend />\n                  </button>\n\n                </form>\n              </Col>\n\n              {/* CONTACT DETAILS */}\n                <Col md={7}>\n                  <div className=\"contacts-details\">\n                    <a\n                      href={`mailto:fano.randriamisaina@gmail.com`}\n                      className=\"personal-details\"\n                    >\n                      <div className=\"detailsIcon\">\n                        <FiAtSign />\n                      </div>\n                      <p style={{ color: \"#fbd9ad\" }}>\n                        fano.randriamisaina@gmail.com\n                      </p>\n                    </a>\n\n                    <a\n                      href=\"https://www.google.com/maps/place/Montpellier,+France\"\n                      target=\"_blank\"\n                      rel=\"noopener noreferrer\"\n                      className=\"personal-details\"\n                    >\n                      <div className=\"personal-details\">\n                        <div className=\"detailsIcon\">\n                          <HiOutlineLocationMarker />\n                        </div>\n                        <p style={{ color: \"#fbd9ad\" }}>\n                          Montpellier, France\n                        </p>\n                      </div>\n                    </a>\n                  </div>\n                  <div className=\"contact-map\">\n                    <iframe\n                      src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2887.1549!2d3.876716!3d43.610769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12b6af3c3f0d1a6f%3A0x1c3c7c6a2d1c9b0!2sMontpellier!5e0!3m2!1sen!2sfr!4v1700000000000\"\n                      frameBorder=\"0\"\n                      allowFullScreen=\"\"\n                      aria-hidden=\"false\"\n                      title=\"Contact Me\"\n                      tabIndex=\"0\"\n                      loading=\"lazy\"\n                      className=\"\"\n                    ></iframe>\n                  </div>\n                </Col>\n              </Row>\n            </Col>\n          </Row>\n        </Container>\n      </Container>\n\n  );\n}\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/components/projects/Projects.js",["164"],[],"import React, { useContext } from \"react\";\nimport Particle from \"../../Particle\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport { Fade } from \"react-reveal\";\nimport LanguageContext from \"../../LanguageContext\";\nimport fog from \"../../images/home-bg.jpg\";\nimport linux from \"../../images/pc.png\";\nimport proxmox from \"../../images/pm.png\";\nimport rag from \"../../images/pg.png\";\nimport rdf from \"../../images/skill.png\";\nimport { FaCode } from \"react-icons/fa\";\nimport { Link } from \"react-router-dom\";\nimport { HiArrowRight } from \"react-icons/hi\";\n\nexport default function Projects() {\n  const { t } = useContext(LanguageContext);\n\n  return (\n    <div>\n      <Container fluid className=\"certificate-section\" id=\"about\">\n        <Container>\n\n          <Row>\n            <Col md={12} className=\"d-flex justify-content-start\">\n              <Zoom left cascade>\n                <h1 className=\"aboutme-heading\">{t.projects.title}</h1>\n              </Zoom>\n            </Col>\n\n            {/* FOG PROJECT */}\n            <Col md={3}>\n              <Fade bottom>\n                <div className=\"singleProject\" style={{ backgroundColor: \"rgb(142 70 186 / 31%)\", border: \"1px solid\" }}>\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Déploiement automatisé (FOG Project)\n                    </h5>\n\n                    <img src={fog} alt=\"fog\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a href=\"https://github.com/2Randi\" target=\"_blank\" rel=\"noreferrer\">\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p className=\"project--desc\" style={{ background: \"#fbd9ad\", color: \"#b061df\" }}>\n                    Automatisation du déploiement d’OS et gestion d’images machines.\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Linux, PXE, FOG Project\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* LINUX SERVICES */}\n            <Col md={3}>\n              <Fade bottom>\n                <div className=\"singleProject\" style={{ backgroundColor: \"rgb(142 70 186 / 31%)\", border: \"1px solid\" }}>\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Services infrastructure Linux\n                    </h5>\n\n                    <img src={linux} alt=\"linux\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a href=\"https://github.com/2Randi\" target=\"_blank\" rel=\"noreferrer\">\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p className=\"project--desc\" style={{ background: \"#fbd9ad\", color: \"#b061df\" }}>\n                    Déploiement et administration Asterisk, OpenVPN, GLPI, Zabbix.\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Linux, Asterisk, OpenVPN, GLPI, Zabbix\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* PROXMOX */}\n            <Col md={3}>\n              <Fade bottom>\n                <div className=\"singleProject\" style={{ backgroundColor: \"rgb(142 70 186 / 31%)\", border: \"1px solid\" }}>\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Backup & migration Proxmox\n                    </h5>\n\n                    <img src={proxmox} alt=\"proxmox\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a href=\"https://github.com/2Randi\" target=\"_blank\" rel=\"noreferrer\">\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p className=\"project--desc\" style={{ background: \"#fbd9ad\", color: \"#b061df\" }}>\n                    Sauvegarde, restauration et migration de machines virtuelles.\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Proxmox, Virtualisation, Linux\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* RAG */}\n            <Col md={3}>\n              <Fade bottom>\n                <div className=\"singleProject\" style={{ backgroundColor: \"rgb(142 70 186 / 31%)\", border: \"1px solid\" }}>\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Système RAG (IA)\n                    </h5>\n\n                    <img src={rag} alt=\"rag\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a href=\"https://github.com/2Randi\" target=\"_blank\" rel=\"noreferrer\">\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p className=\"project--desc\" style={{ background: \"#fbd9ad\", color: \"#b061df\" }}>\n                    Système de génération augmentée par récupération avec Python.\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Python, IA, NLP\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* RDF */}\n            <Col md={3}>\n              <Fade bottom>\n                <div className=\"singleProject\" style={{ backgroundColor: \"rgb(142 70 186 / 31%)\", border: \"1px solid\" }}>\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Graphes RDF / SKOS\n                    </h5>\n\n                    <img src={rdf} alt=\"rdf\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a href=\"https://github.com/2Randi\" target=\"_blank\" rel=\"noreferrer\">\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p className=\"project--desc\" style={{ background: \"#fbd9ad\", color: \"#b061df\" }}>\n                    Indexation et interrogation de graphes sémantiques.\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Python, RDF, SKOS\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n          </Row>\n\n          <div className=\"blog--viewAll\">\n            <Link to=\"/projectspage\">\n              <button className=\"btn btn-primary\">\n                {t.projects.viewAll}\n                <HiArrowRight className=\"viewArr\" />\n              </button>\n            </Link>\n          </div>\n\n        </Container>\n      </Container>\n    </div>\n  );\n}\n",{"ruleId":"165","severity":1,"message":"166","line":4,"column":24,"nodeType":"167","messageId":"168","endLine":4,"endColumn":35},{"ruleId":"165","severity":1,"message":"166","line":9,"column":24,"nodeType":"167","messageId":"168","endLine":9,"endColumn":35},{"ruleId":"169","severity":1,"message":"170","line":12,"column":1,"nodeType":"171","messageId":"172","endLine":12,"endColumn":31},{"ruleId":"165","severity":1,"message":"173","line":12,"column":3,"nodeType":"167","messageId":"168","endLine":12,"endColumn":10},{"ruleId":"165","severity":1,"message":"174","line":8,"column":8,"nodeType":"167","messageId":"168","endLine":8,"endColumn":22},{"ruleId":"165","severity":1,"message":"175","line":9,"column":8,"nodeType":"167","messageId":"168","endLine":9,"endColumn":15},{"ruleId":"165","severity":1,"message":"176","line":10,"column":8,"nodeType":"167","messageId":"168","endLine":10,"endColumn":16},{"ruleId":"165","severity":1,"message":"177","line":4,"column":3,"nodeType":"167","messageId":"168","endLine":4,"endColumn":17},{"ruleId":"165","severity":1,"message":"178","line":6,"column":10,"nodeType":"167","messageId":"168","endLine":6,"endColumn":17},{"ruleId":"165","severity":1,"message":"179","line":2,"column":8,"nodeType":"167","messageId":"168","endLine":2,"endColumn":16},"no-unused-vars","'FaFacebookF' is defined but never used.","Identifier","unusedVar","no-lone-blocks","Block is redundant.","BlockStatement","redundantBlock","'DiReact' is defined but never used.","'JavascriptIcon' is defined but never used.","'CssIcon' is defined but never used.","'HtmlIcon' is defined but never used.","'AiFillFacebook' is defined but never used.","'FiPhone' is defined but never used.","'Particle' is defined but never used."]