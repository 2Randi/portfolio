",["155"],[],"import React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport { AiFillGithub, AiFillInstagram } from \"react-icons/ai\";\nimport { FaLinkedinIn, FaFacebookF, FaGoogle } from \"react-icons/fa\";\n\nfunction Footer() {\n  let date = new Date();\n  let year = date.getFullYear();\n  return (\n    <Container fluid className=\"footer\">\n      <Row>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Designed and Developed by RANDRIAMISAINA Tsiory</h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Copyright © {year} RANDRIAMISAINA Tsiory</h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-body\">\n          <ul className=\"footer-icons\">\n            <li className=\"social-icons\">\n              <a\n                href=\"https://github.com/2Randi\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <AiFillGithub />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.linkedin.com/in/t-fanomezana-r/\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <FaLinkedinIn />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.instagram.com/tsiory_randi/\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <AiFillInstagram />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"mailto:fano.randriamisaina@gmail.com/\"\n                style={{ color: \"white\" }}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n              >\n                <FaGoogle />\n              </a>\n            </li>\n          </ul>\n        </Col>\n      </Row>\n    </Container>\n  );\n}\n\nexport default Footer;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/home_page/HomePage.js",["156"],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/resume_page/ResumePage.js",["157"],[],"import { Container } from \"react-bootstrap\";\nimport Button from \"react-bootstrap/Button\";\nimport { AiOutlineDownload } from \"react-icons/ai\";\nimport Particle from \"../../Particle\";\nimport pdf from \"../../assets/RANDRIAMISAINA_CV.pdf\";\nimport { Document, Page, pdfjs } from \"react-pdf\";\nimport \"react-pdf/dist/esm/Page/AnnotationLayer.css\";\nimport Zoom from \"react-reveal/Zoom\";\nimport React, { useState, useEffect } from \"react\";\npdfjs.GlobalWorkerOptions.workerSrc = `//cdnjs.cloudflare.com/ajax/libs/pdf.js/${pdfjs.version}/pdf.worker.min.js`;\n\n{/* lien du CV dans github */ }\n// \nconst resumeLink = pdf;\n\nfunction Resume() {\n  const [width, setWidth] = useState(1200);\n\n  useEffect(() => {\n    setWidth(window.innerWidth);\n  }, []);\n\n  return (\n    <div>\n      <section className=\"home-section\">\n        <Container fluid id=\"home\">\n          <Particle />\n          <Container className=\"home-content\">\n            <div\n              className=\"d-flex justify-content-center\"\n              width=\"100%\"\n              style={{ backgroundColor: \"#fbd9ad\" }}\n            >\n              <Zoom left cascade>\n                <h1 style={{ color: \"rgb(134 61 176)\" }}>RESUME</h1>\n              </Zoom>\n            </div>\n            <div fluid className=\"certificate-section\" id=\"about\">\n              <div className=\"d-flex justify-content-center mt-4\">\n                <Button variant=\"primary\" href={pdf} target=\"_blank\">\n                  <AiOutlineDownload />\n                  &nbsp;Download Resume\n                </Button>\n              </div>\n              <div className=\"resume d-flex justify-content-center\">\n                <Document file={resumeLink}>\n                  <Page pageNumber={1} scale={width > 786 ? 1.6 : 0.4} />\n                </Document>\n              </div>\n              <div className=\"d-flex justify-content-center\">\n                <Button variant=\"primary\" href={pdf} target=\"_blank\">\n                  <AiOutlineDownload />\n                  &nbsp;Download Resume\n                </Button>\n              </div>\n            </div>\n          </Container>\n        </Container>\n      </section>\n    </div>\n  );\n}\n\nexport default Resume;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/project_page/ProjectPage.js",["158"],[],"import React, { useContext } from \"react\";\nimport Particle from \"../../Particle\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport { Fade } from \"react-reveal\";\n\nimport LanguageContext from \"../../LanguageContext\";\nimport fog from \"../../images/fog.png\";\nimport linux from \"../../images/linux.png\";\nimport proxmox from \"../../images/proxmox.png\";\nimport rag from \"../../images/rag.png\";\nimport { FaCode } from \"react-icons/fa\";\n\nexport default function ProjectPage() {\n  const { t } = useContext(LanguageContext);\n\n  return (\n    <section className=\"home-section\">\n      <Container fluid id=\"home\">\n        <Particle />\n        <Container className=\"home-content\">\n\n          <div\n            className=\"d-flex justify-content-center\"\n            width=\"100%\"\n            style={{ backgroundColor: \"#fbd9ad\" }}\n          >\n            <Zoom left cascade>\n              <h1 style={{ color: \"rgb(134 61 176\" }}>Projects</h1>\n            </Zoom>\n          </div>\n\n          <div>\n\n            <div>\n              <Container fluid className=\"certificate-section\" id=\"about\">\n\n                <Container>\n\n                  <Row>\n\n                    <Col md={12} className=\"mt-5\">\n\n                      <Row className=\"g-5\">\n\n                        {/* Project 1 */}\n                        <Col md={3} className=\"col-sm-12 col-md-4\">\n                          <Fade bottom>\n                            <div\n                              key={1}\n                              className=\"singleProject\"\n                              style={{\n                                backgroundColor: \"rgb(142 70 186 / 31%)\",\n                                border: \"1px solid\",\n                              }}\n                            >\n                              <div className=\"projectContent\">\n                                <h5 id={\"first\"} style={{ color: \"#fbd9ad\" }}>\n                                  Automated OS Deployment (FOG Project)\n                                </h5>\n                                <img src={fog} alt={fog} />\n                                <div className=\"project--showcaseBtn\">\n                                  <a\n                                    href={\n                                      \"https://github.com/2Randi\"\n                                    }\n                                    target=\"_blank\"\n                                    rel=\"noreferrer\"\n                                    className={\"iconBtn\"}\n                                    aria-labelledby={`code`}\n                                  >\n                                    <FaCode\n                                      id={`code`}\n                                      className={\"icon\"}\n                                      aria-label=\"Code\"\n                                    />\n                                  </a>\n                                </div>\n                              </div>\n                              <h6>\n                                <p\n                                  className=\"project--desc\"\n                                  style={{\n                                    background: \"#fbd9ad\",\n                                    color: \"#b061df\",\n                                    fontWeight: 600,\n                                  }}\n                                >\n                                  Automated operating system deployment and machine image\n                                  management\n                                </p>\n                              </h6>\n                              <div\n                                className=\"project--lang\"\n                                style={{\n                                  background: \"#fbd9ad\",\n                                  color: \"#b061df\",\n                                  fontWeight: 600,\n                                }}\n                              >\n                                Linux, PXE, FOG Project\n                              </div>\n                            </div>\n                          </Fade>\n                        </Col>\n\n\n                        {/* Project 2 */}\n                        <Col md={3} className=\"col-sm-12 col-md-4\">\n                          <Fade bottom>\n                            <div\n                              key={1}\n                              className=\"singleProject\"\n                              style={{\n                                backgroundColor: \"rgb(142 70 186 / 31%)\",\n                                border: \"1px solid\",\n                              }}\n                            >\n                              <div className=\"projectContent\">\n                                <h5 id={\"first\"} style={{ color: \"#fbd9ad\" }}>\n                                  Linux Infrastructure Services\n                                </h5>\n                                <img src={linux} alt={linux} />\n                                <div className=\"project--showcaseBtn\">\n                                  <a\n                                    href={\n                                      \"https://github.com/2Randi/\"\n                                    }\n                                    target=\"_blank\"\n                                    rel=\"noreferrer\"\n                                    className={\"iconBtn\"}\n                                    aria-labelledby={`code`}\n                                  >\n                                    <FaCode\n                                      id={`code`}\n                                      className={\"icon\"}\n                                      aria-label=\"Code\"\n                                    />\n                                  </a>\n                                </div>\n                              </div>\n                              <h6>\n                                <p\n                                  className=\"project--desc\"\n                                  style={{\n                                    background: \"#fbd9ad\",\n                                    color: \"#b061df\",\n                                    fontWeight: 600,\n                                  }}\n                                >\n                                  Deployment and administration of Asterisk, OpenVPN, GLPI and Zabbix\n                                </p>\n                              </h6>\n                              <div\n                                className=\"project--lang\"\n                                style={{\n                                  background: \"#fbd9ad\",\n                                  color: \"#b061df\",\n                                  fontWeight: 600,\n                                }}\n                              >\n                                Linux, Asterisk, OpenVPN, GLPI, Zabbix\n                              </div>\n                            </div>\n                          </Fade>\n                        </Col>\n\n                        {/* Project 3 */}\n                        <Col md={3} className=\"col-sm-12 col-md-4\">\n                          <Fade bottom>\n                            <div\n                              key={1}\n                              className=\"singleProject\"\n                              style={{\n                                backgroundColor: \"rgb(142 70 186 / 31%)\",\n                                border: \"1px solid\",\n                              }}\n                            >\n                              <div className=\"projectContent\">\n                                <h5 id={\"first\"} style={{ color: \"#fbd9ad\" }}>\n                                  Proxmox Backup & Migration\n                                </h5>\n                                <img src={proxmox} alt={proxmox} />\n                                <div className=\"project--showcaseBtn\">\n                                  <a\n                                    href={\n                                      \"https://github.com/2Randi/\"\n                                    }\n                                    target=\"_blank\"\n                                    rel=\"noreferrer\"\n                                    className={\"iconBtn\"}\n                                    aria-labelledby={`code`}\n                                  >\n                                    <FaCode\n                                      id={`code`}\n                                      className={\"icon\"}\n                                      aria-label=\"Code\"\n                                    />\n                                  </a>\n                                </div>\n                              </div>\n                              <h6>\n                                <p\n                                  className=\"project--desc\"\n                                  style={{\n                                    background: \"#fbd9ad\",\n                                    color: \"#b061df\",\n                                    fontWeight: 600,\n                                  }}\n                                >\n                                  Backup, restore and migration of virtual machines\n                                </p>\n                              </h6>\n                              <div\n                                className=\"project--lang\"\n                                style={{\n                                  background: \"#fbd9ad\",\n                                  color: \"#b061df\",\n                                  fontWeight: 600,\n                                }}\n                              >\n                                Proxmox, Virtualization, Linux\n                              </div>\n                            </div>\n                          </Fade>\n                        </Col>\n\n                        {/* Project 4 */}\n                        <Col md={3} className=\"col-sm-12 col-md-4\">\n                          <Fade bottom>\n                            <div\n                              key={1}\n                              className=\"singleProject\"\n                              style={{\n                                backgroundColor: \"rgb(142 70 186 / 31%)\",\n                                border: \"1px solid\",\n                              }}\n                            >\n                              <div className=\"projectContent\">\n                                <h5 id={\"first\"} style={{ color: \"#fbd9ad\" }}>\n                                  Knowledge Graph & RAG System\n                                </h5>\n                                <img src={rag} alt={rag} />\n                                <div className=\"project--showcaseBtn\">\n                                  <a\n                                    href={\n                                      \"https://github.com/2Randi/\"\n                                    }\n                                    target=\"_blank\"\n                                    rel=\"noreferrer\"\n                                    className={\"iconBtn\"}\n                                    aria-labelledby={`code`}\n                                  >\n                                    <FaCode\n                                      id={`code`}\n                                      className={\"icon\"}\n                                      aria-label=\"Code\"\n                                    />\n                                  </a>\n                                </div>\n                              </div>\n                              <h6>\n                                <p\n                                  className=\"project--desc\"\n                                  style={{\n                                    background: \"#fbd9ad\",\n                                    color: \"#b061df\",\n                                    fontWeight: 600,\n                                  }}\n                                >\n                                  Development of a semantic knowledge graph and Retrieval-Augmented\n                                  Generation (RAG) system for information indexing and retrieval\n                                </p>\n                              </h6>\n                              <div\n                                className=\"project--lang\"\n                                style={{\n                                  background: \"#fbd9ad\",\n                                  color: \"#b061df\",\n                                  fontWeight: 600,\n                                }}\n                              >\n                                Python, RDF, SKOS, SPARQL, AI\n                              </div>\n                            </div>\n                          </Fade>\n                        </Col>\n\n                      </Row>\n\n                    </Col>\n\n                  </Row>\n\n                </Container>\n\n              </Container>\n\n            </div>\n\n          </div>\n        </Container>\n\n      </Container>\n\n    </section>\n  );\n}\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/certificate_page/CertificatePage.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/comingsoon_page/comingsoon.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/blogs_page/notfound.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/about/About.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/ranking/Ranking.js",["159","160","161","162","163"],[],"import React, { useContext } from \"react\";\nimport {\n  AiFillGithub,\n  AiFillLinkedin,\n} from \"react-icons/ai\";\nimport { FaGoogle } from \"react-icons/fa\";\nimport { Container, Row } from \"react-bootstrap\";\nimport { Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport LanguageContext from \"../../../LanguageContext\";\n\nexport default function Ranking() {\n  const { t } = useContext(LanguageContext);\n  return (\n    <div className=\"mt-4\">\n      <Zoom left cascade>\n        <h3>Coming Soon...</h3>\n      </Zoom>\n      <Container className=\"mt-5\">\n        <Row className=\"g-5\">\n          {/* <Col md={3}>\n            <a\n              href=\"https://github.com/2Randi\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiFillGithub />\n              </Zoom>\n            </a>\n          </Col>\n          <Col md={3}>\n            <a\n              href=\"https://www.linkedin.com/in/t-fanomezana-r/\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiFillLinkedin />\n              </Zoom>\n            </a>\n          </Col>\n          <Col md={3}>\n            <a\n              href=\"mailto:fano.randriamisaina@gmail.com\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <FaGoogle />\n              </Zoom>\n            </a>\n          </Col> */}\n        </Row>\n      </Container>\n    </div>\n  );\n}\n// import React from 'react'\n// import Particle from '../../Particle'\n// import { Container } from \"react-bootstrap\";\n\n// export default function Notfound() {\n//   return (\n//     <section className=\"home-section\">\n//       <Container fluid id=\"home\" >\n//         <Particle />\n//         <Container className=\"home-content d-flex justify-content-center align-items-center comingsoonclass\">\n\n//           <lottie-player src=\"https://assets6.lottiefiles.com/packages/lf20_zkzzfkke.json\" background=\"transparent\" speed=\"1\" style={{ width: '40%', height: '100%' }} loop autoplay></lottie-player>\n//         </Container>\n//       </Container>\n//     </section>\n//   )\n// }\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/EducationJourney.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/ExperienceJourney.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/TechnicalJourney.js",["164"],[],"import React from \"react\";\nimport {\n  VerticalTimeline,\n  VerticalTimelineElement,\n} from \"react-vertical-timeline-component\";\nimport { Link } from \"react-router-dom\";\nimport StarIcon from \"@mui/icons-material/Star\";\nimport ComputerIcon from \"@mui/icons-material/Computer\";\nimport {\n  DiLinux,\n  DiPython,\n  DiDatabase,\n  DiJava,\n} from \"react-icons/di\";\nimport { SiPowershell, SiProxmox, SiGit } from \"react-icons/si\";\nimport { FaNetworkWired, FaShieldAlt } from \"react-icons/fa\";\nimport { MdMonitor } from \"react-icons/md\";\nimport Flip from \"react-reveal/Flip\";\n\nfunction TechnicalJourney() {\n  return (\n    <div className=\"mt-5\">\n      <div>\n        <Link className=\"btn btn-primary m-1\" to=\"/educationjourney\">\n          Educational Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/experiencejourney\">\n          Experience Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/technicaljourney\">\n          Technical Journey\n        </Link>\n        <Link className=\"btn btn-primary m-1\" to=\"/projectjourney\">\n          Project Journey\n        </Link>\n      </div>\n      <div className=\"mt-5\">\n        <Flip top cascade>\n          <h1>Technical Journey</h1>\n        </Flip>\n      </div>\n\n      <VerticalTimeline>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiLinux />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Linux Administration\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<FaNetworkWired />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Networking (TCP/IP, VLAN, Routing, VPN)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<ComputerIcon />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Virtualization (Proxmox, VMWare)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<FaShieldAlt />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Security (pfSense, IPTABLES)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<MdMonitor />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Monitoring (Zabbix, Grafana)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiPython />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Python\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiJava />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Java\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<SiPowershell />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Bash & PowerShell Scripting\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<DiDatabase />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Databases (PostgreSQL, MariaDB, SQL Server, MongoDB)\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          className=\"vertical-timeline-element--work\"\n          contentStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          contentArrowStyle={{ borderRight: \"7px solid  rgb(78 22 112)\" }}\n          date=\"\"\n          iconStyle={{ background: \"rgb(78 22 112)\", color: \"#fbd9ad\" }}\n          icon={<SiGit />}\n        >\n          <h3 className=\"vertical-timeline-element-title\">\n            Git & Version Control\n          </h3>\n        </VerticalTimelineElement>\n\n        <VerticalTimelineElement\n          iconStyle={{ background: \"#fbd9ad\", color: \"rgb(78 22 112)\" }}\n          icon={<StarIcon />}\n        />\n      </VerticalTimeline>\n\n    </div>\n  );\n}\n\nexport default TechnicalJourney;\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/journey/ProjectJourney.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/skills/PersonalSkill.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/skills/TechnicalSkill.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/skills/Toolkit.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/social_media/SocialMedia.js",["165"],[],"import React, { useContext } from \"react\";\nimport {\n  AiOutlineInstagram,\n  AiFillFacebook,\n  AiFillGithub,\n  AiFillLinkedin,\n} from \"react-icons/ai\";\nimport { Container, Row } from \"react-bootstrap\";\nimport { Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport LanguageContext from \"../../../LanguageContext\";\n\nexport default function SocialMedia() {\n  const { t } = useContext(LanguageContext);\n  return (\n    <div className=\"mt-4\">\n      <Zoom left cascade>\n        <h1>{t.socialMedia.title}</h1>\n      </Zoom>\n      <Container className=\"mt-5\">\n        <Row className=\"g-5\">\n\n          <Col md={3}>\n            <a\n              href=\"https://www.instagram.com/tsiory_randi/\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiOutlineInstagram />\n              </Zoom>\n            </a>\n          </Col>\n\n          <Col md={3}>\n            <a\n              href=\"https://github.com/2Randi\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiFillGithub />\n              </Zoom>\n            </a>\n          </Col>\n          <Col md={3}>\n            <a\n              href=\"https://www.linkedin.com/in/t-fanomezana-r/\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"icon-colour  home-social-icons\"\n            >\n              <Zoom cascade>\n                <AiFillLinkedin />\n              </Zoom>\n            </a>\n          </Col>\n        </Row>\n      </Container>\n    </div>\n  );\n}\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/Particle.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/pages/home_page/Typing.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/aboutme/aboutmeContainer.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/certificate/Certification.js",[],[],"/home/randriamisaina/Bureau/portfolio/portfolio/src/components/contactus/Contactus.js",["166"],[],"import React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport { useState } from \"react\";\nimport { AiOutlineSend } from \"react-icons/ai\";\nimport { FiPhone, FiAtSign } from \"react-icons/fi\";\nimport { HiOutlineLocationMarker } from \"react-icons/hi\";\n\nexport default function Contactus() {\n  const [formData, setFormData] = useState({\n    name: \"\",\n    email: \"\",\n    message: \"\"\n  });\n\n  const handleChange = (e) => {\n    setFormData({\n      ...formData,\n      [e.target.name]: e.target.value\n    });\n  };\n\n  const handleSubmit = async (e) => {\n    e.preventDefault();\n\n    try {\n      const res = await fetch(\"https://formspree.io/f/mdadlqrg\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Accept: \"application/json\"\n        },\n        body: JSON.stringify(formData)\n      });\n\n      if (res.ok) {\n        alert(`Message envoyé, merci ${formData.name}`);\n        setFormData({ name: \"\", email: \"\", message: \"\" });\n      } else {\n        alert(\"Erreur envoi message\");\n      }\n    } catch (err) {\n      alert(\"Erreur réseau\");\n    }\n  };\n\n  return (\n    <Container fluid className=\"certificate-section\" id=\"about\">\n      <Container>\n        <Row>\n\n          {/* TITLE */}\n          <Col md={12} className=\"d-flex justify-content-start\">\n            <Zoom left cascade>\n              <h1 className=\"aboutme-heading\">Contact me</h1>\n            </Zoom>\n          </Col>\n\n          <Col md={12} id=\"contact\" className=\"mt-3\">\n            <Row>\n\n              {/* FORM */}\n              <Col md={4}>\n                <div className=\"contacts-form\" data-aos=\"fade-up\">\n                  <form onSubmit={handleSubmit}>\n\n                    <div className=\"input-container d-flex flex-column\">\n                      <label className=\"label-class\">\n                        Full Name\n                      </label>\n                      <input\n                        type=\"text\"\n                        className=\"form-input input-class\"\n                        name=\"name\"\n                        value={formData.name}\n                        onChange={handleChange}\n                        placeholder=\"Enter your name\"\n                        required\n                      />\n                    </div>\n\n                    <div className=\"input-container d-flex flex-column\">\n                      <label className=\"label-class\">\n                        Email\n                      </label>\n                      <input\n                        type=\"email\"\n                        name=\"email\"\n                        className=\"form-input input-class\"\n                        value={formData.email}\n                        onChange={handleChange}\n                        placeholder=\"Enter email\"\n                        required\n                      />\n                    </div>\n\n                    <div className=\"input-container d-flex flex-column\">\n                      <label className=\"label-class\">\n                        Message\n                      </label>\n                      <textarea\n                        className=\"form-message input-class\"\n                        name=\"message\"\n                        rows=\"3\"\n                        value={formData.message}\n                        onChange={handleChange}\n                        placeholder=\"Enter message\"\n                        required\n                      />\n                    </div>\n                    <div className=\"submit-btn\">\n                      <button type=\"submit\" className=\"submitBtn\">\n                        Submit <AiOutlineSend className=\"send-icon\" />\n                      </button>\n                    </div>\n\n                  </form>\n                </div>\n              </Col>\n\n              {/* CONTACT DETAILS */}\n              <Col md={7}>\n                <div className=\"contacts-details\">\n                  <a\n                    href={`mailto:fano.randriamisaina@gmail.com`}\n                    className=\"personal-details\"\n                  >\n                    <div className=\"detailsIcon\">\n                      <FiAtSign />\n                    </div>\n                    <p style={{ color: \"#fbd9ad\" }}>\n                      fano.randriamisaina@gmail.com\n                    </p>\n                  </a>\n\n                  <a\n                    href=\"https://www.google.com/maps/place/Montpellier,+France\"\n                    target=\"_blank\"\n                    rel=\"noopener noreferrer\"\n                    className=\"personal-details\"\n                  >\n                    <div className=\"personal-details\">\n                      <div className=\"detailsIcon\">\n                        <HiOutlineLocationMarker />\n                      </div>\n                      <p style={{ color: \"#fbd9ad\" }}>\n                        Montpellier, France\n                      </p>\n                    </div>\n                  </a>\n                </div>\n                <div className=\"contact-map\">\n                  <iframe\n                    src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2887.1549!2d3.876716!3d43.610769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12b6af3c3f0d1a6f%3A0x1c3c7c6a2d1c9b0!2sMontpellier!5e0!3m2!1sen!2sfr!4v1700000000000\"\n                    frameBorder=\"0\"\n                    allowFullScreen=\"\"\n                    aria-hidden=\"false\"\n                    title=\"Contact Me\"\n                    tabIndex=\"0\"\n                    loading=\"lazy\"\n                    className=\"\"\n                  ></iframe>\n                </div>\n              </Col>\n            </Row>\n          </Col>\n        </Row>\n      </Container>\n    </Container>\n\n  );\n}\n","/home/randriamisaina/Bureau/portfolio/portfolio/src/components/projects/Projects.js",["167"],[],"import React, { useContext } from \"react\";\nimport Particle from \"../../Particle\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport Zoom from \"react-reveal/Zoom\";\nimport { Fade } from \"react-reveal\";\nimport LanguageContext from \"../../LanguageContext\";\nimport fog from \"../../images/fog.png\";\nimport linux from \"../../images/linux.png\";\nimport proxmox from \"../../images/proxmox.png\";\nimport rag from \"../../images/rag.png\";\nimport { FaCode } from \"react-icons/fa\";\nimport { Link } from \"react-router-dom\";\nimport { HiArrowRight } from \"react-icons/hi\";\n\nexport default function Projects() {\n  const { t } = useContext(LanguageContext);\n\n  return (\n    <div>\n      <Container fluid className=\"certificate-section\" id=\"about\">\n        <Container>\n          <Row>\n            <Col md={12} className=\"d-flex justify-content-start\">\n              <Zoom left cascade>\n                <h1 className=\"aboutme-heading\">{t.projects.title}</h1>\n              </Zoom>\n            </Col>\n\n            {/* FOG PROJECT */}\n            <Col md={3}>\n              <Fade bottom>\n                <div\n                  className=\"singleProject\"\n                  style={{\n                    backgroundColor: \"rgb(142 70 186 / 31%)\",\n                    border: \"1px solid\",\n                  }}\n                >\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Automated OS Deployment (FOG Project)\n                    </h5>\n\n                    <img src={fog} alt=\"fog\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a\n                        href=\"https://github.com/2Randi\"\n                        target=\"_blank\"\n                        rel=\"noreferrer\"\n                      >\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p\n                    className=\"project--desc\"\n                    style={{\n                      background: \"#fbd9ad\",\n                      color: \"#b061df\",\n                    }}\n                  >\n                    Automated operating system deployment and machine image\n                    management\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Linux, PXE, FOG Project\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* LINUX SERVICES */}\n            <Col md={3}>\n              <Fade bottom>\n                <div\n                  className=\"singleProject\"\n                  style={{\n                    backgroundColor: \"rgb(142 70 186 / 31%)\",\n                    border: \"1px solid\",\n                  }}\n                >\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Linux Infrastructure Services\n                    </h5>\n\n                    <img src={linux} alt=\"linux\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a\n                        href=\"https://github.com/2Randi\"\n                        target=\"_blank\"\n                        rel=\"noreferrer\"\n                      >\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p\n                    className=\"project--desc\"\n                    style={{\n                      background: \"#fbd9ad\",\n                      color: \"#b061df\",\n                    }}\n                  >\n                    Deployment and administration of Asterisk, OpenVPN, GLPI and Zabbix\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Linux, Asterisk, OpenVPN, GLPI, Zabbix\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* PROXMOX */}\n            <Col md={3}>\n              <Fade bottom>\n                <div\n                  className=\"singleProject\"\n                  style={{\n                    backgroundColor: \"rgb(142 70 186 / 31%)\",\n                    border: \"1px solid\",\n                  }}\n                >\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Proxmox Backup & Migration\n                    </h5>\n\n                    <img src={proxmox} alt=\"proxmox\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a\n                        href=\"https://github.com/2Randi\"\n                        target=\"_blank\"\n                        rel=\"noreferrer\"\n                      >\n                        <FaCode />\n                      </a>\n                    </div>\n                  </div>\n\n                  <p\n                    className=\"project--desc\"\n                    style={{\n                      background: \"#fbd9ad\",\n                      color: \"#b061df\",\n                    }}\n                  >\n                    Backup, restore and migration of virtual machines\n                  </p>\n\n                  <div className=\"project--lang\">\n                    Proxmox, Virtualization, Linux\n                  </div>\n                </div>\n              </Fade>\n            </Col>\n\n            {/* KNOWLEDGE GRAPH & RAG */}\n            <Col md={3}>\n              <Fade bottom>\n                <div\n                  className=\"singleProject\"\n                  style={{\n                    backgroundColor: \"rgb(142 70 186 / 31%)\",\n                    border: \"1px solid\",\n                  }}\n                >\n                  <div className=\"projectContent\">\n                    <h5 style={{ color: \"#fbd9ad\" }}>\n                      Knowledge Graph & RAG System\n                    </h5>\n\n                    <img src={rag} alt=\"knowledge-graph-rag\" />\n\n                    <div className=\"project--showcaseBtn\">\n                      <a\n                        href=\"https://github.com/2Randi\"\n      